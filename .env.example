# WhatsApp Cloud API Configuration
# Copy this file to .env and fill in your actual values

# Get your access token from Meta Developer Console:
# https://developers.facebook.com/ → Your App → WhatsApp → API Setup → Generate access token
ACCESS_TOKEN=your_access_token_here

# Receiver phone number (without + sign)
# Must be added to allowed list in Meta Developer Console
# Example: 917385107084
RECEIVER_NUMBER=
